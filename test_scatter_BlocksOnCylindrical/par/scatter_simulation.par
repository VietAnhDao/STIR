Scatter Simulation Parameters :=
Scatter Simulation type := PET Single Scatter Simulation
PET Single Scatter Simulation Parameters :=

template projdata filename := ${TEMPLATE}

attenuation image filename := ${ATTEN_IMAGE}

activity image filename := ${ACTIVITY_IMAGE}

output filename prefix := ${OUTPUT_PREFIX}

attenuation threshold := 0.01 
use cache := 1

End PET Single Scatter Simulation Parameters:=
End Scatter Simulation Parameters:=
